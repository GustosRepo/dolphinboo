{
  "name": "dolphinboo",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "npm run start --workspace=apps/mobile",
    "web": "npm run dev --workspace=apps/web",
    "admin": "npm run dev --workspace=apps/admin",
    "type-check": "npm run type-check --workspaces --if-present"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.5"
  },
  "overrides": {
    "tailwindcss": "^3.4.0"
  }
}
