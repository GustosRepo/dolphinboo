{
  "expo": {
    "name": "DolphinBoo",
    "slug": "dolphinboo",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "dolphinboo",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#f5ede0"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dolphinboo.app"
    },
    "android": {
      "package": "com.dolphinboo.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#f5ede0"
      }
    }
  }
}
